<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0D0518" />
        </shape>
    </item>
    <item
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#3A205E"
                android:centerColor="#231238"
                android:endColor="#140A22" />
        </shape>
    </item>
</layer-list>
