<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp">
        <shape android:shape="oval">
            <solid android:color="#160D25" />
            <stroke
                android:width="2dp"
                android:color="#D8B35D" />
        </shape>
    </item>

    <item
        android:left="11dp"
        android:top="11dp"
        android:right="11dp"
        android:bottom="11dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#43296D"
                android:centerColor="#2A1642"
                android:endColor="#1A0E2A" />
            <stroke
                android:width="1dp"
                android:color="#26FFFFFF" />
        </shape>
    </item>

    <item
        android:left="12dp"
        android:top="12dp"
        android:right="12dp"
        android:bottom="12dp">
        <bitmap
            android:gravity="fill"
            android:src="@drawable/card_joker_icon" />
    </item>
</layer-list>
